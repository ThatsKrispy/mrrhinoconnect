/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

# Hashed assets — immutable forever (hash changes on any update)
/assets/css/style.*.css
  Cache-Control: public, max-age=31536000, immutable

/assets/js/*.js
  Cache-Control: public, max-age=31536000, immutable

# Images — 90 day cache with revalidation
/assets/images/*.jpg
  Cache-Control: public, max-age=7776000, stale-while-revalidate=86400

/assets/images/*.png
  Cache-Control: public, max-age=7776000, stale-while-revalidate=86400

# Fonts loaded by Google — handled by Google's CDN, nothing to set here

# HTML — revalidate on every request so updates land immediately
/*.html
  Cache-Control: no-cache, must-revalidate

/
  Cache-Control: no-cache, must-revalidate

/services/*.html
  Cache-Control: no-cache, must-revalidate

/news/*.html
  Cache-Control: no-cache, must-revalidate
